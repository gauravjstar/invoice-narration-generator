# Database Configuration
DATABASE_URL=postgresql://invoice_user:invoice_password@db:5432/invoice_db
DATABASE_ECHO=False

# OpenAI Configuration
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o

# OCR Configuration
OCR_ENGINE=paddleocr  # Options: paddleocr, tesseract, easyocr
OCR_LANGUAGE=en
OCR_CONFIDENCE_THRESHOLD=0.7

# Application Configuration
SECRET_KEY=your-super-secret-key-min-32-characters-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=True

# File Upload Configuration
MAX_UPLOAD_SIZE=52428800  # 50MB in bytes
UPLOAD_FOLDER=./uploads
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png

# Batch Processing
BATCH_SIZE_LIMIT=1000
MAX_WORKERS=4
PROCESS_TIMEOUT=300  # seconds

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Email Configuration (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@invoicenarration.com

# Redis Configuration (Optional)
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# AWS S3 Configuration (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=invoice-uploads
AWS_S3_REGION_NAME=us-east-1

# Duplicate Detection Threshold
DUPLICATE_SIMILARITY_THRESHOLD=0.95

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60  # seconds

# Environment
ENVIRONMENT=development  # development, staging, production
DEBUG=True
